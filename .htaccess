##############################################################################
## BLOCAGE IP MALVEILLANTES (analyse logs)
##############################################################################
<RequireAll>
    Require ip 142.171.134.194
    Require all granted
    Require not ip 196.196.53.93
    Require not ip 20.220.232.240
</RequireAll>

##############################################################################
## BLOCAGE BOTS AGRESSIFS (SEO / SCRAPING)
##############################################################################
<IfModule mod_setenvif.c>
    BrowserMatchNoCase MJ12bot      bad_bot
    BrowserMatchNoCase Bytespider  bad_bot
    BrowserMatchNoCase PetalBot    bad_bot
</IfModule>

<IfModule mod_authz_core.c>
    <RequireAll>
        Require all granted
        Require not env bad_bot
    </RequireAll>
</IfModule>

##############################################################################
## Options de base (sans risque)
##############################################################################
Options +FollowSymlinks
Options -Indexes

##############################################################################
## Interdire le listing de dossier
##############################################################################
<IfModule mod_autoindex.c>
    IndexIgnore *
</IfModule>

##############################################################################
## En-têtes de sécurité
##############################################################################
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set Permissions-Policy "camera=(), microphone=(), geolocation=()"
    Header always set Cross-Origin-Opener-Policy "same-origin-allow-popups"
</IfModule>

##############################################################################
## CACHE – EXPIRES HEADERS
##############################################################################
<IfModule mod_expires.c>
    ExpiresActive On

    # Images
    ExpiresByType image/webp     "access plus 1 year"
    ExpiresByType image/jpeg    "access plus 1 year"
    ExpiresByType image/png     "access plus 1 year"
    ExpiresByType image/gif     "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"

    # Fonts
    ExpiresByType font/ttf   "access plus 1 year"
    ExpiresByType font/otf   "access plus 1 year"
    ExpiresByType font/woff  "access plus 1 year"
    ExpiresByType font/woff2 "access plus 1 year"

    # CSS / JS
    ExpiresByType text/css               "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
</IfModule>

##############################################################################
## COMPRESSION GZIP / DEFLATE (sans .gz précompressé)
##############################################################################
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/xml
    AddOutputFilterByType DEFLATE text/css text/javascript application/javascript
    AddOutputFilterByType DEFLATE application/json application/xml
    AddOutputFilterByType DEFLATE image/svg+xml
</IfModule>

<IfModule mod_headers.c>
    Header append Vary Accept-Encoding
</IfModule>

##############################################################################
## Protection SVG (anti XSS)
##############################################################################
<FilesMatch "\.svg$">
    <IfModule mod_headers.c>
        Header always set Content-Security-Policy "script-src 'none'"
    </IfModule>
</FilesMatch>

##############################################################################
## Joomla SEF & sécurité
##############################################################################
<IfModule mod_rewrite.c>
    RewriteEngine On

    ## Blocage injections classiques
    RewriteCond %{QUERY_STRING} base64_encode[^(]*\([^)]*\) [OR]
    RewriteCond %{QUERY_STRING} (<|%3C)([^s]*s)+cript.*(>|%3E) [NC,OR]
    RewriteCond %{QUERY_STRING} GLOBALS(=|\[|\%[0-9A-Z]{0,2}) [OR]
    RewriteCond %{QUERY_STRING} _REQUEST(=|\[|\%[0-9A-Z]{0,2})
    RewriteRule .* index.php [F]

    ## Base
    RewriteBase /

    ## Authorization header (API / OAuth)
    RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

    ## Routage API Joomla
    RewriteCond %{REQUEST_URI} ^/api/
    RewriteCond %{REQUEST_URI} !^/api/index\.php
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule .* api/index.php [L]

    ## Sitemap XML propre
    RewriteRule ^sitemap\.xml$ /index.php?option=com_jmap&view=sitemap&format=xml [R=301,L]

    ## SEF Frontend

    # AFK: Rediriger les vues RSEvents Pro jour/semaine vers le calendrier de base
    # FR : /calendrier-sessions/jour/... → /calendrier-sessions/
    RewriteRule ^(.*calendrier-sessions)/(jour|semaine|ann[eé]e|day|week|year|COM_RSEVENTSPRO_CALENDAR_[A-Z_]+_SEF)(/.*)? $1/ [R=302,L]
    # EN : /session-calendar/day/... → /session-calendar/
    RewriteRule ^(en/.*session-calendar)/(jour|semaine|ann[eé]e|day|week|year|COM_RSEVENTSPRO_CALENDAR_[A-Z_]+_SEF)(/.*)? $1/ [R=302,L]
    # ZH : même chose
    RewriteRule ^(zh/.*session-calendar)/(jour|semaine|ann[eé]e|day|week|year|COM_RSEVENTSPRO_CALENDAR_[A-Z_]+_SEF)(/.*)? $1/ [R=302,L]

    RewriteCond %{REQUEST_URI} !^/index\.php
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule .* index.php [L]
</IfModule>

##############################################################################
## Fallback si mod_rewrite absent
##############################################################################
<IfModule !mod_rewrite.c>
    <IfModule mod_alias.c>
        RedirectMatch 302 ^/$ /index.php/
    </IfModule>
</IfModule>

##############################################################################
## Désactivation fichiers précompressés (.gz / .br)
##############################################################################
<FilesMatch "\.(css\.gz|js\.gz|css\.br|js\.br)$">
    <IfModule mod_headers.c>
        Header unset Content-Encoding
        Header unset Content-Type
        Header set Content-Type text/plain
        Header set X-Blocked-Compressed true
    </IfModule>
    Require all denied
</FilesMatch>